{
  "compilerOptions": {
    "target": "ES5",
    "lib": ["ES5", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "jsx": "react",
    "strict": true,
    "noEmit": true,
    "types": ["office-js", "node"]
  },
  "include": [
    "src/polyfills.ts",
    "src/settings/store.legacy.ts",
    "src/settings/defaults.ts",
    "src/hooks/useSettingsStore.legacy.ts",
    "src/telemetry/telemetry.legacy.ts",
    "src/llm/**/*.ts",
    "src/types/**/*.ts",
    "src/agent/**/*.ts",
    "src/taskpane/main.legacy.tsx",
    "src/taskpane/App.legacy.tsx",
    "src/taskpane/components.legacy/**/*.tsx"
  ]
}